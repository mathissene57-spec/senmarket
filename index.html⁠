function bindKeyboard() {
  document.addEventListener('keydown', function(e) {
    var isEsc = e.key==='Escape'||e.key==='Esc'||e.keyCode===27;
    if (!isEsc) return;
    if (document.getElementById('boutiquePage').classList.contains('on')) { closeBoutique(); return; }
    if (document.getElementById('regPage').classList.contains('on'))      { closeInscription(); return; }
    if (document.getElementById('cartSheet').classList.contains('on'))    { closeCart_(); return; }
  });
}

/* ================================================================
   TOAST
   ================================================================ */
function showToast(msg, type, dur) {
  /* FIX: dedup */
  var key = msg+type;
  if (ST._toastMap[key]) return;
  ST._toastMap[key] = true;
  setTimeout(function(){ delete ST._toastMap[key]; }, 1800);

  var c = document.getElementById('toasts');
  var t = document.createElement('div');
  t.className = 'toast'+(type==='e'?' e':type==='w'?' w':'');
  var icons = {s:'✅',e:'❌',w:'⚠️',i:'ℹ️'};
  t.innerHTML = '<span>'+( icons[type]||'ℹ️' )+'</span><span style="flex:1">'+h(msg)+'</span><span class="toast-x" role="button" tabindex="0" aria-label="Fermer">&#10005;</span>';
  t.querySelector('.toast-x').addEventListener('click', function(){ dismiss(t); });
  c.appendChild(t);
  requestAnimationFrame(function(){ requestAnimationFrame(function(){ t.classList.add('show'); }); });
  var d = dur || 3200;
  setTimeout(function(){ dismiss(t); }, d);
}
function dismiss(t) {
  if (!t.parentNode) return;
  t.classList.add('hiding'); t.classList.remove('show');
  setTimeout(function(){ if(t.parentNode) t.remove(); }, 380);
}

})(); /* end IIFE */
