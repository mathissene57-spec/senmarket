/* ================================================================
   RENDER PRODUCTS
   ================================================================ */
function renderProdsHome()      { renderProdsToEl('prodsHome', PRODS.slice(0,6)); }
function renderProdsPage(cat)   {
  var list = cat ? PRODS.filter(function(p){ return p.cat === cat; }) : PRODS;
  renderProdsToEl('prodsPage', list);
  document.getElementById('prodsPageCount').textContent = list.length;
}
function renderProdsToEl(id, list) {
  var el = document.getElementById(id);
  el.innerHTML = list.length
    ? list.map(function(p){ return cardProd(p); }).join('')
    : '<div style="grid-column:1/-1;text-align:center;padding:40px;color:var(--mut)">Aucun produit</div>';
  bindProdEvents(el);
}
function bindProdEvents(container) {
  container.addEventListener('click', function(e) {
    var fav  = e.target.closest('.pc-fav');
    var wa   = e.target.closest('.bwa');
    var cart = e.target.closest('.bcart');
    if (fav) {
      e.stopPropagation();
      var pid  = fav.dataset.pid;
      var pname= fav.dataset.pname;
      toggleFav(pid, pname, fav);
      return;
    }
    if (wa)  { e.stopPropagation(); var p=getP(wa.dataset.pid); if(p) waProd(p); return; }
    if (cart){ e.stopPropagation(); var p=getP(cart.dataset.pid); if(p) addCart(p); return; }
  });
}
function getP(id) { return PRODS.find(function(p){ return p.id===id; })||null; }

function cardProd(p) {
  var isFav = ST.favs.indexOf(p.id) > -1;
  var low = p.stock > 0 && p.stock <= 3;
  return '<article class="prod-card" role="listitem">'
    +'<div class="pc-img '+h(p.img)+'">'
    + (p.badge ? '<span class="pc-badge b-'+h(p.badge)+'">'+badgeLabel(p.badge)+'</span>' : '')
    +'<button class="pc-fav" data-pid="'+h(p.id)+'" data-pname="'+h(p.name)+'" aria-label="'+(isFav?'Retirer des':'Ajouter aux')+' favoris">'+(isFav?'❤️':'🤍')+'</button>'
    + (p.stock>0 ? '<span class="pc-stk">'+(low?'⚠️ '+p.stock:p.stock+' stk')+'</span>' : '<span class="pc-stk" style="background:rgba(196,30,58,.55)">Epuise</span>')
    +'<span style="font-size:48px;position:relative;z-index:1">'+p.emoji+'</span>'
    +'</div>'
    +'<div class="pc-body">'
    +'<div class="pc-shop">'+h(p.shop)+'</div>'
    +'<div class="pc-name">'+h(p.name)+'</div>'
    +'<div class="pc-stars">'+stars(p.rating)+' <span style="color:var(--mut);font-size:9px">('+p.reviews+')</span></div>'
    +'<div class="pc-foot">'
    +'<div class="pc-price">'+p.price+' <small>'+h(p.currency)+'</small></div>'
    +'<div class="pc-acts">'
    +'<button class="bwa"  data-pid="'+h(p.id)+'" aria-label="Commander via WhatsApp">💬</button>'
    +'<button class="bcart" data-pid="'+h(p.id)+'" aria-label="Ajouter au panier">🛒</button>'
    +'</div></div></div></article>';
}

/* ================================================================
   FAVORIS
   ================================================================ */
function toggleFav(id, name, btn) {
  var idx = ST.favs.indexOf(id);
  if (idx > -1) {
    ST.favs.splice(idx,1);
    btn.textContent = '🤍';
    btn.setAttribute('aria-label','Ajouter aux favoris');
    showToast('"'+name+'" retire des favoris','i');
  } else {
    ST.favs.push(id);
    btn.textContent = '❤️';
    btn.setAttribute('aria-label','Retirer des favoris');
    showToast('"'+name+'" ajoute aux favoris !','s');
  }
  lsSet('sm3_favs', ST.favs);
  updateFavBadge();
  if (ST.page === 'favoris') renderFavs();
}

function renderFavs() {
  var favProds = PRODS.filter(function(p){ return ST.favs.indexOf(p.id) > -1; });
  var el = document.getElementById('prodsFavs');
  if (!favProds.length) {
    el.innerHTML = '<div style="grid-column:1/-1" class="favs-empty"><div class="fe-ico">❤️</div><div class="fe-ttl">Aucun favori</div><div class="fe-sub">Appuyez sur le coeur pour sauvegarder</div></div>';
    return;
  }
  el.innerHTML = favProds.map(function(p){ return cardProd(p); }).join('');
  bindProdEvents(el);
}

function updateFavBadge() {
  var n = ST.favs.length;
  document.getElementById('favDot').classList.toggle('show', n > 0);
  document.getElementById('favCountMenu').textContent = n + ' produit' + (n>1?'s':'');
}

/* ================================================================
   CART
   ================================================================ */
function addCart(p) {
  var ex = ST.cart.find(function(i){ return i.id === p.id; });
  if (ex) ex.qty++;
  else ST.cart.push({id:p.id,name:p.name,price:p.price,emoji:p.emoji,img:p.img,qty:1});
  lsSet('sm3_cart', ST.cart);
  updateCartBadge();
  showToast('"'+p.name+'" ajoute au panier !','s');
}
function updateQty(id, d) {
  var item = ST.cart.find(function(i){ return i.id===id; });
  if (!item) return;
  item.qty += d;
  if (item.qty <= 0) ST.cart.splice(ST.cart.indexOf(item),1);
  lsSet('sm3_cart', ST.cart);
  updateCartBadge();
  renderCartBody();
}
function updateCartBadge() {
  var total = ST.cart.reduce(function(s,i){ return s+i.qty; },0);
  var b = document.getElementById('cartBadge');
  b.textContent = total;
  b.classList.toggle('show', total>0);
}
function renderCartBody() {
  var body = document.getElementById('cartBody');
  var foot = document.getElementById('cartFoot');
  if (!ST.cart.length) {
    body.innerHTML = '<div class="cart-empty"><div class="ce-ico">🛒</div><div class="ce-ttl">Panier vide</div><div class="ce-sub">Decouvrez nos boutiques</div></div>';
    foot.style.display = 'none'; return;
  }
  foot.style.display = 'block';
  var total = ST.cart.reduce(function(s,i){ return s+i.price*i.qty; },0);
  document.getElementById('cartTotalAmt').textContent = total.toLocaleString('fr-MA')+' MAD';
  body.innerHTML = ST.cart.map(function(item){
    return '<div class="ci-row">'
      +'<div class="ci-img '+h(item.img)+'">'+item.emoji+'</div>'
      +'<div class="ci-info"><h4>'+h(item.name)+'</h4><p>'+(item.price*item.qty).toLocaleString('fr-MA')+' MAD</p></div>'
      +'<div class="ci-qty">'
      +'<button class="qty-b" data-cid="'+h(item.id)+'" data-qd="-1" aria-label="Reduire">&#8722;</button>'
      +'<span class="qty-n">'+item.qty+'</span>'
      +'<button class="qty-b" data-cid="'+h(item.id)+'" data-qd="1" aria-label="Augmenter">+</button>'
      +'</div></div>';
  }).join('');
}
function openCart()  { renderCartBody(); openSheet('cart'); }
function closeCart_() { closeSheet('cart'); }

function checkout() {
  if (!ST.cart.length) return;
  var lines = ST.cart.map(function(i){ return i.qty+'x '+i.name+' -- '+i.price+' MAD'; }).join('\n');
  var total = ST.cart.reduce(function(s,i){ return s+i.price*i.qty; },0);
  var msg   = encodeURIComponent('Bonjour ! Je souhaite commander via SenMarket :\n\n'+lines+'\n\nTotal: '+total+' MAD\n\nMerci de confirmer ma commande.');
  window.open('https://wa.me/+212644696608?text='+msg,'_blank');
}

function bindCart() {
  document.getElementById('closeCart').addEventListener('click', closeCart_);
  document.getElementById('cartOverlay').addEventListener('click', closeCart_);
  document.getElementById('btnCheckout').addEventListener('click', checkout);
  document.getElementById('cartBody').addEventListener('click', function(e) {
    var btn = e.target.closest('.qty-b');
    if (!btn) return;
    updateQty(btn.dataset.cid, parseInt(btn.dataset.qd,10));
  });
}

