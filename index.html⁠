      +'<div style="display:flex;gap:10px"><span style="color:var(--mut);width:80px">WhatsApp</span><a href="https://wa.me/'+s.wa.replace(/\D/g,'')+'" style="color:#25D366;font-weight:600">Envoyer un message</a></div>'
