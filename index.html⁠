  var pg  = document.getElementById('page-'+page);
  var tab = document.getElementById('tab-'+page);
  if (pg)  { pg.classList.add('on'); }
  if (tab) { tab.classList.add('on'); tab.setAttribute('aria-selected','true'); }
  ST.page = page;
  window.scrollTo(0,0);
}

