function openBoutique(id) {
  var s = SHOPS.find(function(x){ return x.id===id; });
  if (!s) return;
  ST.shopOpen = s;
  document.getElementById('bpLogo').textContent    = s.emoji;
  document.getElementById('bpCoverBg').className   = 'bp-cover-bg '+s.cover;
  document.getElementById('bpName').textContent    = s.name;
  document.getElementById('bpOwner').textContent   = '🇸🇳 '+s.owner+' -- '+s.city;
  document.getElementById('bpDesc').textContent    = s.desc || '';
  document.getElementById('bpSP').textContent      = fNum(s.prods);
  document.getElementById('bpSV').textContent      = fNum(s.sales);
  document.getElementById('bpSN').textContent      = s.rating+'⭐';
  document.getElementById('bpSF').textContent      = fNum(s.followers);
  /* reset follow */
  var isFoll = ST.favs.indexOf('shop-'+s.id) > -1;
  var fb = document.getElementById('bpBtnFoll');
  fb.textContent = isFoll ? '♥ Abonne' : '♡ Suivre';
  fb.classList.toggle('on', isFoll);
  /* load tab */
  switchBpTab('prods');
  document.getElementById('boutiquePage').classList.add('on');
  lockScroll();
}
function closeBoutique() {
  document.getElementById('boutiquePage').classList.remove('on');
  unlockScroll();
  ST.shopOpen = null;
}
