.bp-tabs { display:flex; border-bottom:1px solid var(–bdr); background:#fff; overflow-x:auto; scrollbar-width:none; }
.bp-tabs::-webkit-scrollbar { display:none; }
.bp-tab { flex:1; padding:13px 10px; font-size:13px; font-weight:600; color:var(–mut); border-bottom:2px solid transparent; cursor:pointer; white-space:nowrap; text-align:center; min-width:80px; transition:all .2s; }
.bp-tab.on { color:var(–g); border-bottom-color:var(–g); }

.bp-content { padding:16px; }

/* ================================================================
INSCRIPTION VENDEUR (full screen)
================================================================ */
.reg-page {
display:none; position:fixed; inset:0; z-index:440;
background:var(–bg); overflow-y:auto;
}
.reg-page.on { display:block; }

.reg-nav {
position:sticky; top:0; z-index:10; height:52px;
background:rgba(250,247,242,.96);
backdrop-filter:blur(16px); -webkit-backdrop-filter:blur(16px);
border-bottom:1px solid var(–bdr);
display:flex; align-items:center; justify-content:space-between;
padding:0 16px;
}
.reg-step-lbl { font-size:13px; color:var(–mut); font-weight:600; }

.reg-prog { height:3px; background:var(–bdrs); }
.reg-prog-fill { height:100%; background:var(–g); border-radius:0 2px 2px 0; transition:width .4s var(–ease); will-change:width; }

.reg-body { padding:20px 20px calc(80px + var(–safe)); }
.reg-step { display:none; }
.reg-step.on { display:block; }
.reg-h1  { font-family:‘Playfair Display’,serif; font-size:22px; font-weight:900; margin-bottom:6px; }
.reg-sub { font-size:14px; color:var(–mut); margin-bottom:24px; line-height:1.6; }

.reg-fixed {
position:fixed; bottom:0; left:0; right:0;
padding:12px 20px calc(12px + var(–safe));
background:rgba(250,247,242,.97);
backdrop-filter:blur(12px); -webkit-backdrop-filter:blur(12px);
border-top:1px solid var(–bdr); z-index:10;
display:flex; gap:10px;
}
.reg-fixed button { flex:1; }

/* ================================================================
PANIER (bottom sheet)
================================================================ */
.sheet-overlay {
position:fixed; inset:0;
background:rgba(0,0,0,.45); z-index:var(–z-sh);
opacity:0; pointer-events:none;
transition:opacity .25s;
backdrop-filter:blur(2px); -webkit-backdrop-filter:blur(2px);
will-change:opacity;
}
.sheet-overlay.on { opacity:1; pointer-events:auto; }

.sheet {
position:fixed; bottom:0; left:0; right:0; z-index:calc(var(–z-sh) + 1);
background:#fff; border-radius:24px 24px 0 0;
padding:0 0 calc(24px + var(–safe));
transform:translateY(100%);
transition:transform .35s var(–ease);
max-height:92vh; overflow-y:auto;
box-shadow:0 -8px 40px rgba(0,0,0,.13);
will-change:transform; overscroll-behavior:contain;
}
.sheet.on { transform:translateY(0); }

.sh-handle { width:36px; height:4px; background:var(–bdr); border-radius:2px; margin:12px auto 4px; }
.sh-hd { display:flex; align-items:center; justify-content:space-between; padding:12px 20px 4px; }
.sh-title { font-family:‘Playfair Display’,serif; font-size:18px; font-weight:900; }
.sh-close { width:32px; height:32px; border-radius:50%; background:var(–bgw); border:1px solid var(–bdr); display:flex; align-items:center; justify-content:center; font-size:15px; cursor:pointer; transition:background .15s; }
.sh-close:active { background:var(–bdr); }
.sh-body { padding:8px 20px; }

/* Cart items */
.ci-row { display:flex; align-items:center; gap:12px; padding:12px 0; border-bottom:1px solid var(–bdrs); }
.ci-img { width:56px; height:56px; border-radius:var(–r12); display:flex; align-items:center; justify-content:center; font-size:24px; flex-shrink:0; }
.ci-info { flex:1; min-width:0; }
.ci-info h4 { font-size:14px; font-weight:600; margin-bottom:2px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.ci-info p  { font-size:13px; color:var(–g); font-weight:700; }
.ci-qty { display:flex; align-items:center; gap:8px; flex-shrink:0; }
.qty-b { width:28px; height:28px; border-radius:8px; border:1px solid var(–bdr); background:var(–bgw); font-size:16px; font-weight:700; display:flex; align-items:center; justify-content:center; cursor:pointer; transition:all .15s; }
.qty-b:active { background:var(–g); color:#fff; border-color:var(–g); }
.qty-n { font-size:15px; font-weight:700; min-width:20px; text-align:center; }
.cart-empty { text-align:center; padding:48px 20px; }
.cart-empty .ce-ico  { font-size:48px; margin-bottom:12px; }
.cart-empty .ce-ttl  { font-size:17px; font-weight:700; margin-bottom:6px; }
.cart-empty .ce-sub  { font-size:14px; color:var(–mut); }
.cart-total { display:flex; justify-content:space-between; align-items:center; padding:14px 0 0; border-top:1px solid var(–bdr); margin-top:4px; }
.cart-total span   { font-size:15px; color:var(–mut); }
.cart-total strong { font-family:‘Playfair Display’,serif; font-size:22px; color:var(–g); }
.btn-checkout {
width:100%; padding:16px; border-radius:var(–r16);
background:var(–g); color:#fff; font-size:16px; font-weight:700;
display:flex; align-items:center; justify-content:center; gap:8px;
margin-top:12px; border:none; cursor:pointer; font-family:inherit;
transition:all .2s; box-shadow:var(–shg); will-change:transform;
}
.btn-checkout:active { background:var(–gm); transform:scale(.98); }

/* ================================================================
FORMS
================================================================ */
.fg { margin-bottom:16px; }
.fg label { display:block; font-size:13px; font-weight:600; color:var(–txt2); margin-bottom:7px; }
.fg label .req { color:var(–red); margin-left:2px; }
.fi {
width:100%; padding:13px 15px;
border:1.5px solid var(–bdr); border-radius:var(–r12);
font-size:15px; color:var(–txt); background:var(–bgw);
transition:border-color .2s, box-shadow .2s;
}
.fi:focus { border-color:var(–g); box-shadow:0 0 0 3px var(–gg); outline:none; }
.fi::placeholder { color:var(–mut); }
.fi.err { border-color:var(–red); }
textarea.fi { height:80px; resize:none; }
.fi-row  { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
.fi-full { grid-column:1/-1; }
.ferr { font-size:11px; color:var(–red); margin-top:4px; display:none; }
.fi.err + .ferr { display:block; }

/* Strength meter */
.strength-wrap { margin-top:5px; }
.strength-bar  { height:4px; background:var(–bdr); border-radius:2px; overflow:hidden; }
.strength-fill { height:100%; border-radius:2px; transition:width .3s, background .3s; will-change:width; }
.strength-lbl  { font-size:11px; margin-top:3px; font-weight:600; }

/* Upload */
.upload-zone {
border:2px dashed var(–bdr); border-radius:var(–r16);
padding:24px; text-align:center; background:var(–bgw);
cursor:pointer; position:relative; transition:all .2s;
}
.upload-zone:active { border-color:var(–g); background:var(–gg); }
.upload-zone input { position:absolute; inset:0; opacity:0; cursor:pointer; }
.uz-ico { font-size:30px; margin-bottom:6px; }
.uz-txt { font-size:13px; color:var(–mut); }
.uz-hint{ font-size:11px; color:var(–mut); margin-top:3px; }
#logoPreview { width:68px; height:68px; border-radius:50%; object-fit:cover; display:none; margin:10px auto 0; border:3px solid var(–g); }

/* Slug preview */
.slug-preview { font-size:12px; color:var(–mut); margin-top:5px; }
.slug-preview strong { color:var(–g); }

/* Buttons */
.btn-p {
width:100%; padding:15px; border-radius:var(–r16);
background:var(–g); color:#fff; font-size:15px; font-weight:700;
border:none; cursor:pointer; font-family:inherit;
display:flex; align-items:center; justify-content:center; gap:8px;
transition:all .2s; margin-top:8px; box-shadow:var(–shg);
will-change:transform;
}
.btn-p:active   { background:var(–gm); transform:scale(.98); }
.btn-p:disabled { opacity:.55; cursor:not-allowed; pointer-events:none; }
.btn-s {
width:100%; padding:13px; border-radius:var(–r16);
background:transparent; color:var(–txt2);
border:1.5px solid var(–bdr); font-size:14px; font-weight:600;
cursor:pointer; font-family:inherit; margin-top:8px; transition:all .2s;
}
.btn-s:active { border-color:var(–g); color:var(–g); }

/* Toggle */
.toggle {
width:42px; height:24px; border-radius:var(–rpill);
background:var(–mut); position:relative; cursor:pointer;
transition:background .25s var(–ease); border:none; flex-shrink:0;
will-change:background;
}
.toggle.on { background:var(–g); }
.toggle::after {
content:’’; position:absolute; top:3px; left:3px;
width:18px; height:18px; border-radius:50%; background:#fff;
transition:transform .25s var(–ease); will-change:transform;
}
.toggle.on::after { transform:translateX(18px); }

/* ================================================================
PROFIL PAGE
================================================================ */
.profile-hero {
background:linear-gradient(135deg,var(–g),#003d21);
padding:clamp(32px,5vw,52px) 20px 64px;
text-align:center; position:relative;
}
.profile-hero::after {
content:’’; position:absolute; bottom:0; left:0; right:0; height:36px;
background:var(–bg); border-radius:36px 36px 0 0;
}
.ph-av   { width:78px; height:78px; border-radius:50%; border:3px solid #fff; background:var(–gm); display:flex; align-items:center; justify-content:center; font-size:36px; margin:0 auto 12px; box-shadow:var(–shl); }
.ph-name { font-family:‘Playfair Display’,serif; font-size:20px; font-weight:900; color:#fff; margin-bottom:4px; }
.ph-email{ font-size:13px; color:rgba(255,255,255,.65); }

.pcard { background:var(–card); border:1px solid var(–bdr); border-radius:var(–r16); margin:0 16px 12px; overflow:hidden; }
.pcard-ttl { font-size:12px; font-weight:700; color:var(–mut); text-transform:uppercase; letter-spacing:.7px; padding:13px 16px 8px; border-bottom:1px solid var(–bdrs); }
.pcard-item { display:flex; align-items:center; gap:12px; padding:13px 16px; border-bottom:1px solid var(–bdrs); cursor:pointer; transition:background .15s; }
.pcard-item:last-child { border-bottom:none; }
.pcard-item:active { background:var(–bgw); }
.pi-ico { width:36px; height:36px; border-radius:var(–r8); display:flex; align-items:center; justify-content:center; font-size:18px; flex-shrink:0; }
.pi-g { background:var(–gg); }
.pi-r { background:var(–redb); }
.pi-b { background:rgba(61,142,255,.09); }
.pi-y { background:rgba(212,160,23,.1); }
.pi-txt strong { display:block; font-size:14px; font-weight:600; }
.pi-txt span   { font-size:12px; color:var(–mut); }
.pi-arr { margin-left:auto; font-size:18px; color:var(–mut); }

/* ================================================================
FAVORIS PAGE
================================================================ */
.favs-empty { text-align:center; padding:60px 20px; }
.fe-ico { font-size:52px; margin-bottom:14px; }
.fe-ttl { font-family:‘Playfair Display’,serif; font-size:20px; font-weight:700; margin-bottom:8px; }
.fe-sub { font-size:14px; color:var(–mut); }

/* ================================================================
BOUTIQUES PAGE – full grid
================================================================ */
.shops-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; padding:0 16px; }
@media(min-width:480px)  { .shops-grid { grid-template-columns:repeat(3,1fr); } }
@media(min-width:768px)  { .shops-grid { grid-template-columns:repeat(4,1fr); gap:16px; padding:0 24px; } }

/* ================================================================
TOAST
================================================================ */
#toasts {
position:fixed;
bottom:calc(var(–tab) + var(–safe) + 10px);
left:12px; right:12px;
z-index:var(–z-tst);
display:flex; flex-direction:column; gap:7px;
pointer-events:none;
}
.toast {
background:#fff; border:1px solid var(–bdr); border-left:4px solid var(–g);
padding:12px 16px; border-radius:var(–r12); font-size:14px; font-weight:500;
box-shadow:var(–shl);
display:flex; align-items:center; gap:10px;
transform:translateY(14px); opacity:0;
transition:all .3s var(–ease);
pointer-events:auto; will-change:transform,opacity;
}
.toast.show   { transform:translateY(0); opacity:1; }
.toast.hiding { transform:translateY(8px); opacity:0; }
.toast.e { border-left-color:var(–red); }
.toast.w { border-left-color:var(–gold); }
.toast-x { margin-left:auto; cursor:pointer; font-size:14px; color:var(–mut); flex-shrink:0; }
.toast-x:active { color:var(–txt); }

/* ================================================================
SKELETON
================================================================ */
.skel {
background:linear-gradient(90deg,#f0ebe3 25%,#e5dfd6 50%,#f0ebe3 75%);
background-size:200% 100%;
animation:shim 1.5s infinite;
will-change:background-position;
}
@keyframes shim { 0%{background-position:200% 0} 100%{background-position:-200% 0} }
.skel-prod { border-radius:var(–r16); }

/* ================================================================
RESPONSIVE – desktop
================================================================ */
@media(min-width:768px) {
body { padding-bottom:0; }
#btmnav { display:none; }
#topnav { height:68px; padding:0 clamp(24px,5%,80px); }
.page { padding-top:68px; }
.sec-hd { padding:20px clamp(24px,5%,80px) 12px; }
.search-sticky { padding:12px clamp(24px,5%,80px) 14px; }
.hscroll { padding:10px clamp(24px,5%,80px) 16px; }
.hero-banner { margin:14px clamp(24px,5%,80px); }
}

/* Flag stripe */
.flag { height:5px; display:flex; }
.f-g{flex:1;background:var(–g)}
.f-y{flex:1;background:var(–goldb)}
.f-r{flex:1;background:var(–red)}

/* Vendor CTA section */
.vendor-cta {
margin:16px 16px 0;
background:linear-gradient(135deg,var(–g) 0%,#004d2b 60%,#002a17 100%);
border-radius:var(–r20); padding:24px 20px;
position:relative; overflow:hidden; color:#fff; text-align:center;
}
.vendor-cta::before { content:’’; position:absolute; inset:0; background:radial-gradient(circle at 70% 50%,rgba(245,184,0,.12) 0%,transparent 65%); pointer-events:none; }
.vc-in  { position:relative; z-index:1; }
.vc-h2  { font-family:‘Playfair Display’,serif; font-size:20px; font-weight:900; margin-bottom:8px; line-height:1.25; }
.vc-h2 span { color:var(–goldb); }
.vc-sub { font-size:13px; opacity:.8; margin-bottom:18px; line-height:1.65; }
.vc-feats { display:flex; flex-wrap:wrap; gap:10px; justify-content:center; margin-bottom:18px; }
.vc-feat { display:flex; align-items:center; gap:6px; font-size:12px; font-weight:600; }
.vc-chk  { width:20px; height:20px; border-radius:50%; background:rgba(255,255,255,.18); display:flex; align-items:center; justify-content:center; font-size:10px; font-weight:700; flex-shrink:0; }
</style>

</head>

