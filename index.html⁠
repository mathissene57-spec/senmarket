function bindBoutique() {
  document.getElementById('btnBoutiqueBack').addEventListener('click', closeBoutique);
  document.getElementById('bpBtnWa').addEventListener('click', function(){ if(ST.shopOpen) waShop(ST.shopOpen.wa, ST.shopOpen.name); });
  document.getElementById('bpBtnFoll').addEventListener('click', function(){
    var s = ST.shopOpen; if (!s) return;
    var k = 'shop-'+s.id; var idx = ST.favs.indexOf(k);
    var fb = document.getElementById('bpBtnFoll');
    if (idx > -1) { ST.favs.splice(idx,1); fb.textContent='♡ Suivre'; fb.classList.remove('on'); showToast('Boutique retiree des favoris','i'); }
    else          { ST.favs.push(k); fb.textContent='♥ Abonne'; fb.classList.add('on'); showToast('Vous suivez '+s.name+' !','s'); }
    lsSet('sm3_favs', ST.favs); updateFavBadge();
  });
  document.getElementById('btnBoutiqueShare').addEventListener('click', function(){
    var s = ST.shopOpen; if (!s) return;
    var url = window.location.origin+'/boutique/'+genSlug(s.name);
    if (navigator.share) { navigator.share({title:s.name,url:url}).catch(function(){}); }
    else if (navigator.clipboard) { navigator.clipboard.writeText(url).then(function(){ showToast('Lien copie !','s'); }); }
  });
  document.getElementById('bpTabs').addEventListener('click', function(e){
    var tab = e.target.closest('.bp-tab');
    if (tab) switchBpTab(tab.dataset.bptab);
  });
}

/* ================================================================
   INSCRIPTION VENDEUR
   ================================================================ */
function openInscription() {
  ST.regStep = 1;
  updateRegUI();
  document.getElementById('regPage').classList.add('on');
  lockScroll();
}
function closeInscription() {
  document.getElementById('regPage').classList.remove('on');
  unlockScroll();
  ST.regStep = 1;
}
function updateRegUI() {
  var s = ST.regStep;
  document.querySelectorAll('.reg-step').forEach(function(el,i){ el.classList.toggle('on', i+1===s); });
  document.getElementById('regStepLbl').textContent = 'Etape '+s+' / 3';
  document.getElementById('regFill').style.width = (s/3*100)+'%';
  document.getElementById('btnRegPrev').style.display = s>1 ? 'flex' : 'none';
  document.getElementById('btnRegNext').textContent = s<3 ? 'Continuer →' : '🚀 Creer ma boutique';
}
function validerReg() {
  var s = ST.regStep;
  if (s===1) {
    var nom  = document.getElementById('rNom').value.trim();
    var mail = document.getElementById('rEmail').value.trim();
    var mdp  = document.getElementById('rMdp').value;
    var conf = document.getElementById('rConf').value;
    if (!nom)  { showToast('Entrez votre nom','w'); return false; }
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(mail)) { showToast('Email invalide','w'); return false; }
    if (mdp.length < 8) { showToast('Mot de passe min. 8 caracteres','w'); return false; }
    if (mdp !== conf) { showToast('Mots de passe differents','w'); return false; }
  }
  if (s===2) {
    if (!document.getElementById('rVille').value) { showToast('Choisissez votre ville','w'); return false; }
    if (!document.getElementById('rTel').value.trim()) { showToast('Entrez votre telephone','w'); return false; }
  }
  return true;
}
function soumettreInscription() {
  if (ST.submitting) return;
  var boutique = document.getElementById('rBoutique').value.trim();
  var cat      = document.getElementById('rCat').value;
  var nom      = document.getElementById('rNom').value.trim();
  var email    = document.getElementById('rEmail').value.trim();
  var ville    = document.getElementById('rVille').value;
  var tel      = document.getElementById('rTel').value.trim();
  if (!boutique||!cat) { showToast('Nom de boutique et categorie requis','w'); return; }

  ST.submitting = true;
  var btn = document.getElementById('btnRegNext');
  btn.disabled = true; btn.textContent = '⏳ Creation...';

  var msg = encodeURIComponent('Nouvelle boutique SenMarket !\n\nBoutique: '+boutique+'\nVendeur: '+nom+'\nVille: '+ville+'\nCategorie: '+cat+'\nTel: '+tel+'\nEmail: '+email);
  window.open('https://wa.me/+212644696608?text='+msg,'_blank');

  setTimeout(function() {
    ST.submitting = false;
    btn.disabled = false; btn.textContent = '🚀 Creer ma boutique';
    closeInscription();
    showToast('Boutique "'+boutique+'" creee ! Notre equipe vous contacte sous 24h.','s', 5000);
  }, 800);
}

function bindInscription() {
  document.getElementById('btnRegBack').addEventListener('click', closeInscription);
  document.getElementById('btnMenuOuvrirBoutique').addEventListener('click', openInscription);
  document.getElementById('btnRegPrev').addEventListener('click', function(){
    ST.regStep = Math.max(1, ST.regStep-1); updateRegUI();
  });
  document.getElementById('btnRegNext').addEventListener('click', function(){
    if (!validerReg()) return;
    if (ST.regStep < 3) { ST.regStep++; updateRegUI(); }
    else soumettreInscription();
  });
  document.getElementById('rBoutique').addEventListener('input', function(){
    var slug = genSlug(this.value);
    document.getElementById('slugPreview').textContent = slug ? 'senmarket.ma/boutique/'+slug : 'senmarket.ma/boutique/votre-nom';
  });
  document.getElementById('rMdp').addEventListener('input', function(){
    var v = this.value; var s = 0;
    if (v.length>=8) s++; if (v.length>=12) s++;
    if (/[A-Z]/.test(v)) s++; if (/[0-9]/.test(v)) s++; if (/[^A-Za-z0-9]/.test(v)) s++;
    var lvl = [{c:'#EF4444',l:'Tres faible',p:'20%'},{c:'#F97316',l:'Faible',p:'40%'},{c:'#F59E0B',l:'Moyen',p:'60%'},{c:'#22C55E',l:'Fort',p:'80%'},{c:'#15803D',l:'Tres fort',p:'100%'}];
    var n = Math.min(s,4);
    document.getElementById('sFill').style.width = lvl[n].p;
    document.getElementById('sFill').style.background = lvl[n].c;
    document.getElementById('sLbl').textContent = v ? lvl[n].l : '';
    document.getElementById('sLbl').style.color = lvl[n].c;
  });
  document.getElementById('rLogo').addEventListener('change', function(){
    var f = this.files[0]; if (!f) return;
    var r = new FileReader();
    r.onload = function(e){ var i=document.getElementById('logoPreview'); i.src=e.target.result; i.style.display='block'; };
    r.readAsDataURL(f);
  });
}

